# ─────────────────────────────────────────────────────────────────────────────
# AdminClient — Umgebungsvariablen
# Kopiere diese Datei zu ".env" und passe die Werte an.
#
# Eine .env pro Deployment (Produktion, Staging, …), gemeinsam genutzt von:
#   - dem Node-Server zur LAUFZEIT (GET /health liest process.env direkt)
#   - dem Frontend-Build (nur VITE_*-Variablen — Vite backt sie zur BUILD-ZEIT
#     in den Browser-Bundle ein; alles andere hier bleibt server-only, da Vite
#     ausschließlich VITE_-präfixierte Keys inlined)
#
# Jede Umgebung braucht also einen eigenen Frontend-Build mit eigener .env —
# es gibt keine Laufzeit-Umschaltung zwischen Umgebungen im Browser.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=3000

# ─── Backend: Microservice-URLs für GET /health ───────────────────────────────
# Leer lassen oder auskommentieren, um einen Service aus dem Health-Check auszunehmen.

AUTH_SERVICE_URL=https://auth.freischule.info
FREESCHOOL_URL=https://api.freischule.info
PROFILE_SERVICE_URL=https://profile.freischule.info
EMAIL_SERVICE_URL=https://email.freischule.info
EXCEPTION_SERVICE_URL=https://exception.freischule.info
OBJECT_SERVICE_URL=https://object.freischule.info
MESSAGE_SERVICE_URL=https://message.freischule.info
MEDIA_SERVICE_URL=https://media.freischule.info
GIT_SERVICE_URL=https://git.freischule.info
VIRTUALOFFICE_URL=https://virtualoffice.freischule.info
PRESENCE_SERVICE_URL=https://presence.freischule.info
LIVEKIT_URL=https://live.freischule.info
RECORDING_SERVICE_URL=https://recording.freischule.info

# ─── Frontend: in den Browser-Bundle eingebacken (npm run build:admin) ────────
# Diese Werte spiegeln i.d.R. die Server-URLs oben — Vite verlangt trotzdem das
# VITE_-Präfix, sonst wird die Variable nicht in den Client-Bundle aufgenommen.

VITE_AUTH_SERVICE_URL=https://auth.freischule.info
VITE_FREESCHOOL_URL=https://api.freischule.info
VITE_GIT_SERVICE_URL=https://git.freischule.info
VITE_MEDIA_SERVICE_URL=https://media.freischule.info

# Nur für die Services-Übersicht (Health-Anzeige im Browser):
VITE_VIRTUALOFFICE_URL=https://virtualoffice.freischule.info
VITE_LANDING_URL=https://freischule.info
VITE_LIVEKIT_URL=https://live.freischule.info
VITE_RECORDING_SERVICE_URL=https://recording.freischule.info
VITE_PROFILE_SERVICE_URL=https://profile.freischule.info
