# ─────────────────────────────────────────────────────────────────────────────
# AdminClient — Umgebungsvariablen
# Kopiere diese Datei zu ".env" und passe die Werte an.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=production
SESSION_SECRET=change-this-to-a-long-random-string

# ─── Microservice-URLs ────────────────────────────────────────────────────────
# Der Watchdog prüft alle 10 Sekunden GET / (bzw. GET /health) jedes Services.
# Leer lassen oder auskommentieren, um einen Service aus der Überwachung auszunehmen.

AUTH_SERVICE_URL=https://auth.freischule.info
PROFILE_SERVICE_URL=https://profile.freischule.info
EMAIL_SERVICE_URL=https://email.freischule.info
EXCEPTION_SERVICE_URL=https://exception.freischule.info
OBJECT_SERVICE_URL=https://object.freischule.info
MESSAGE_SERVICE_URL=https://message.freischule.info
RECORDING_SERVICE_URL=https://recording.freischule.info
MEDIA_SERVICE_URL=https://media.freischule.info
GIT_SERVICE_URL=https://git.freischule.info
FREESCHOOL_URL=https://api.freischule.info

# ─── E-Mail-Alerts ────────────────────────────────────────────────────────────
# Wenn ein Service ausfällt, sendet der Watchdog eine Alert-Mail über den
# EmailService. Alle drei Variablen müssen gesetzt sein, damit Alerts aktiv sind.

# API-Key des EmailService (X-API-Key Header, nur für interne Services)
EMAIL_API_KEY=your-email-service-api-key

# Empfänger der Alert-Mails
ALERT_EMAIL_TO=admin@freischule.info

# Absender der Alert-Mails (optional, Standard: monitor@freischule.info)
ALERT_EMAIL_FROM=monitor@freischule.info
