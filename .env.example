# ─────────────────────────────────────────────────────────────────────────────
# AdminClient Server — Umgebungsvariablen
# Kopiere diese Datei zu ".env" und passe die Werte an.
#
# Der Node-Server hat nur zwei Aufgaben: den gebauten React-Client ausliefern
# und GET /health als Aggregator für den Status aller Microservices bereitstellen
# (z.B. konsumiert von VirtualOffice's /api/services/status Proxy).
# Diese URLs werden NICHT an den Browser ausgeliefert.
#
# Frontend-seitige Service-URLs (Login, AuthService, GitService, ...) werden
# separat in frontend/.env als VITE_*-Variablen zur Build-Zeit gesetzt.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=production

# ─── Microservice-URLs für GET /health ────────────────────────────────────────
# Leer lassen oder auskommentieren, um einen Service aus dem Health-Check auszunehmen.

AUTH_SERVICE_URL=https://auth.freischule.info
FREESCHOOL_URL=https://api.freischule.info
PROFILE_SERVICE_URL=https://profile.freischule.info
EMAIL_SERVICE_URL=https://email.freischule.info
EXCEPTION_SERVICE_URL=https://exception.freischule.info
OBJECT_SERVICE_URL=https://object.freischule.info
MESSAGE_SERVICE_URL=https://message.freischule.info
MEDIA_SERVICE_URL=https://media.freischule.info
GIT_SERVICE_URL=https://git.freischule.info
VIRTUALOFFICE_URL=https://virtualoffice.freischule.info
PRESENCE_SERVICE_URL=https://presence.freischule.info
LIVEKIT_URL=https://live.freischule.info
RECORDING_SERVICE_URL=https://recording.freischule.info
