# Server
PORT=3000
NODE_ENV=production
SESSION_SECRET=change-this-to-a-long-random-string

# AuthService (MongoDB-based, JWT RS256)
AUTH_SERVICE_URL=https://auth.freischule.info

# FreeSchool / Internetschule (PostgreSQL-based, JWT HS256)
FREESCHOOL_URL=https://api.freischule.info

# Additional services for log aggregation (all use AuthService JWT)
PRESENCE_SERVICE_URL=https://presence.freischule.info
VIRTUAL_OFFICE_URL=https://virtual-office.freischule.info
PROFIL_SERVICE_URL=https://profil.freischule.info
EMAIL_SERVICE_URL=https://email.freischule.info
